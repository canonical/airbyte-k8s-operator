{
  "__inputs": [],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Airbyte log-based health (from Loki): log-level and error trends, per-component activity, Temporal connectivity, and filtered-error + raw log panels. No application/sync metrics: Airbyte community emits none over OTLP (see the charm's observability docs).",
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": "${lokids}",
      "description": "INFO/WARN/ERROR/DEBUG lines per interval, parsed from the log level in each line.",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": "${lokids}",
          "expr": "sum by (level) (count_over_time({juju_model=~\"$juju_model\", juju_model_uuid=~\"$juju_model_uuid\", juju_application=~\"$juju_application\", juju_unit=~\"$juju_unit\"} | regexp `\\s(?P<level>INFO|WARN|ERROR|DEBUG)\\s` [$__interval]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "title": "Log level distribution",
      "type": "timeseries"
    },
    {
      "datasource": "${lokids}",
      "description": "Rate of log lines containing error/exception/warn (case-insensitive). A rising line is the first sign of trouble.",
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20 }, "unit": "logs/s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": "${lokids}",
          "expr": "sum(rate({juju_model=~\"$juju_model\", juju_model_uuid=~\"$juju_model_uuid\", juju_application=~\"$juju_application\", juju_unit=~\"$juju_unit\"} |~ `(?i)\\b(error|exception|warn)\\b` [$__interval]))",
          "legendFormat": "errors+warnings",
          "refId": "A"
        }
      ],
      "title": "Error & warning rate",
      "type": "timeseries"
    },
    {
      "datasource": "${lokids}",
      "description": "Log volume per Airbyte component, parsed from the [airbyte-*] prefix in each line. Shows which services are active or unusually chatty.",
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": "${lokids}",
          "expr": "sum by (component) (count_over_time({juju_model=~\"$juju_model\", juju_model_uuid=~\"$juju_model_uuid\", juju_application=~\"$juju_application\", juju_unit=~\"$juju_unit\"} | regexp `\\[(?P<component>airbyte-[a-z-]+)\\]` [$__interval]))",
          "legendFormat": "{{component}}",
          "refId": "A"
        }
      ],
      "title": "Log volume by component",
      "type": "timeseries"
    },
    {
      "datasource": "${lokids}",
      "description": "Lines reporting a failed connection to Temporal. Non-zero means the control plane can't reach temporal-k8s (sync orchestration is impaired).",
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": "${lokids}",
          "expr": "sum(count_over_time({juju_model=~\"$juju_model\", juju_model_uuid=~\"$juju_model_uuid\", juju_application=~\"$juju_application\", juju_unit=~\"$juju_unit\"} |~ `temporal.*(Connection refused|UNAVAILABLE)` [$__interval]))",
          "legendFormat": "temporal connectivity errors",
          "refId": "A"
        }
      ],
      "title": "Temporal connectivity errors",
      "type": "timeseries"
    },
    {
      "datasource": "${lokids}",
      "description": "Only error and exception lines, for fast triage.",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 16 },
      "id": 6,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": "${lokids}",
          "expr": "{juju_model=~\"$juju_model\", juju_model_uuid=~\"$juju_model_uuid\", juju_application=~\"$juju_application\", juju_unit=~\"$juju_unit\"} |~ `(?i)error|exception`",
          "refId": "A"
        }
      ],
      "title": "Errors and exceptions",
      "type": "logs"
    },
    {
      "datasource": "${lokids}",
      "description": "Aggregated logs from all Airbyte workload containers.",
      "gridPos": { "h": 13, "w": 24, "x": 0, "y": 25 },
      "id": 1,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": "${lokids}",
          "expr": "{juju_model=~\"$juju_model\", juju_model_uuid=~\"$juju_model_uuid\", juju_application=~\"$juju_application\", juju_unit=~\"$juju_unit\"}",
          "refId": "A"
        }
      ],
      "title": "All logs",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["airbyte"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Airbyte",
  "weekStart": ""
}
